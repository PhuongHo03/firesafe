# Copy this file to .env.local when running frontend manually from source.
# setup.ps1 up auto-generates .env.local, so manual setup is only needed without setup.ps1.
# Docker Compose uses empty values so browser requests go through same-origin Nginx.
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_AI_WORKER_URL=http://localhost:8090
NEXT_PUBLIC_MONITORING_URL=http://localhost:8091
