# FireSafe Docker Compose environment

# Public app bind address. Use 0.0.0.0 so other devices on the same LAN can open http://<host-ip>:3000.
APP_BIND_ADDRESS=0.0.0.0

# Public ports
FRONTEND_PORT=3000
ADMINER_PORT=7001
MINIO_CONSOLE_PORT=7002
REDISINSIGHT_PORT=7003
RABBITMQ_UI_PORT=7004
MARIADB_PORT=7005
MINIO_API_PORT=7006
REDIS_PORT=7007
RABBITMQ_PORT=7008
PROMETHEUS_PORT=7009
RABBITMQ_PROMETHEUS_PORT=7010

# Public browser URLs baked into the frontend image. Empty means same-origin via Nginx.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_AI_WORKER_URL=
NEXT_PUBLIC_PROMETHEUS_URL=

# Database
DB_NAME=firesafe
DB_USER=firesafe
DB_PASSWORD=firesafe
MARIADB_ROOT_PASSWORD=root

# Redis
REDIS_HOST=redis
REDIS_PORT_INTERNAL=6379

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=snapshots

# Backend auth
JWT_SECRET=change-this-to-a-very-long-random-secret-key-at-least-256-bits
FIRESAFE_USERNAME=admin@nhattienchung.vn
FIRESAFE_PASSWORD=admin123

# Optional preset camera seed. Do not commit real RTSP credentials.
FIRESAFE_PRESET_CAMERA_NAME=Camera RTSP Preset
FIRESAFE_PRESET_CAMERA_LOCATION=Preset
FIRESAFE_PRESET_CAMERA_RTSP_URL=

# Optional Telegram notification
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Worker
AI_WORKER_CONF=0.25
AI_WORKER_RTSP_TRANSPORTS=default,udp,tcp
AI_WORKER_RTSP_BUFFER_SIZE=1
AI_WORKER_OVERLAY_TTL_SECONDS=2.0
AI_WORKER_STATUS_CACHE_TTL_SECONDS=1.0
AI_WORKER_SUSTAINED_DETECTION_SECONDS=3.0
AI_WORKER_BATCH_MAX_SIZE=1
AI_WORKER_BATCH_MAX_WAIT_MS=50
AI_WORKER_SCHEDULER_IDLE_SLEEP_MS=5
AI_MODEL_URL=https://huggingface.co/TommyNgx/YOLOv10-Fire-and-Smoke-Detection/resolve/main/best.pt
AI_MODEL_PATH=/app/models/best.pt
HF_TOKEN=
